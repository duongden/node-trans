{
  "name": "node-trans",
  "version": "1.0.0",
  "description": "Real-time audio translation app using Soniox API",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev:server": "node --watch src/server.js",
